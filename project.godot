;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Copenhagen"
run/main_scene="uid://blmijp366barc"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://cxb83prakddd6"

[autoload]

GameManager="*uid://dt6gggynhlc8j"
BackgroundMusic="*uid://d352opnusgyau"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/stretch/mode="viewport"

[file_customization]

folder_colors={
"res://Assets/": "yellow",
"res://Scenes/": "green",
"res://Scripts/": "purple"
}

